{
  "version": 2,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Accept-CH", "value": "Sec-CH-UA-Platform-Version, Sec-CH-UA-Model, Sec-CH-UA-Platform" },
        { "key": "Permissions-Policy", "value": "ch-ua-platform-version=(*), ch-ua-model=(*), ch-ua-platform=(*)" }
      ]
    },
    {
      "source": "/overlay.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
